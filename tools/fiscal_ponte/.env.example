# Copie para .env na pasta tools/fiscal_ponte (não commitar valores reais).

# API Django (mesmo token configurado no servidor: FISCAL_AGENT_TOKEN)
FISCAL_PONTE_API_BASE_URL=http://localhost:8000/api/v1
FISCAL_PONTE_AGENT_TOKEN=trocar-pelo-mesmo-token-do-backend

# CNPJ da ZFW (14 dígitos) — deve ser igual a FISCAL_EMPRESA_CNPJ no backend
# Homologação: use 98765432000188 (destinatário do XML de teste em homolog/fixtures)
FISCAL_PONTE_CNPJ=98765432000188
FISCAL_PONTE_UF=35

# Provedor SEFAZ: stub | acbr | folder
# stub = sem certificado (desenvolvimento)
# acbr = ACBrMonitorPLUS via TCP (produção com A3)
# folder = lê XMLs de um diretório e envia ao servidor (teste/homologação)
FISCAL_PONTE_SEFAZ_PROVIDER=stub

# ACBrMonitor (quando SEFAZ_PROVIDER=acbr)
FISCAL_PONTE_ACBR_HOST=127.0.0.1
FISCAL_PONTE_ACBR_PORT=3434
FISCAL_PONTE_ACBR_TIMEOUT_SEC=120
# Pasta onde o ACBr grava os arquivos referenciados em "arquivo=..." na resposta
FISCAL_PONTE_ACBR_OUTPUT_DIR=C:\ACBrMonitor\ARQUIVOS

# Pasta de XMLs (quando SEFAZ_PROVIDER=folder)
FISCAL_PONTE_FOLDER_XML=C:\temp\nfe-xml

# Serviço / tarefa agendada
FISCAL_PONTE_SYNC_INTERVAL_MIN=15
FISCAL_PONTE_LOG_DIR=
# FISCAL_PONTE_API_RETRY_MAX=3
# FISCAL_PONTE_API_RETRY_BASE_SEC=2
# FISCAL_PONTE_MAX_CICLOS_NSU=20
