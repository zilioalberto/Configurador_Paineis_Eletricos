# Copie para .env na raiz (não commite o .env real).
# DJANGO_DEBUG=true/false — explícito; se omitido, DEBUG segue DJANGO_ENV (ver settings.py).
# DJANGO_ENV=development | production | dev | local — usado pelo docker-compose e como fallback de DEBUG.

DJANGO_SECRET_KEY=trocar-esta-chave
DJANGO_DEBUG=True
DJANGO_ENV=development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

DB_NAME=configurador_painel
DB_USER=configurador_painel
# Obrigatório para `docker compose up`: defina DB_PASSWORD=... no seu .env (o compose não usa valor por omissão).
# Exemplo (não use este valor em produção): crie uma palavra-passe forte só para o Postgres local.
DB_HOST=db
DB_PORT=5432
DB_EXTERNAL_PORT=15432

# Observabilidade (docker-compose.monitoring.yml)
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
# Obrigatório ao subir o overlay de monitoring: defina GRAFANA_ADMIN_PASSWORD=... no seu .env
GRAFANA_ROOT_URL=http://localhost:3000
GRAFANA_DB_NAME=grafana
GRAFANA_DB_USER=grafana
# Obrigatório ao subir o overlay de monitoring: defina GRAFANA_DB_PASSWORD=... no seu .env
TELEGRAM_BOT_NAME=portal_zfw_monitoramento_bot
# Obrigatório para alertas Telegram: defina TELEGRAM_BOT_TOKEN=... no seu .env
# Obrigatório para alertas Telegram: defina TELEGRAM_CHAT_ID=... no seu .env

# Consulta CNPJ (Brasil API) — limites e rate limit por usuário autenticado
CNPJ_CONSULTA_THROTTLE_RATE=30/min
CNPJ_CONSULTA_TIMEOUT_SEC=15
CNPJ_CONSULTA_MAX_SOCIOS=50
CNPJ_CONSULTA_MAX_CNAES=50
CNPJ_CONSULTA_MAX_RESPONSE_BYTES=524288
# CNPJ_BRASILAPI_URL=https://brasilapi.com.br/api/cnpj/v1/{cnpj}

# -----------------------------------------------------------------------------
# E-mail — envio da proposta ao cliente (Enviar ao cliente no orçamento)
# Copie para o .env real; não coloque senhas neste arquivo de exemplo.
# -----------------------------------------------------------------------------
# Desenvolvimento (e-mail só no log do container):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# SMTP ZFW / Hostinger — porta 465 usa SSL (não TLS):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=email-ssl.com.br
# EMAIL_PORT=465
# EMAIL_USE_SSL=true
# EMAIL_USE_TLS=false
# EMAIL_HOST_USER=vendas@zfw.com.br
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=vendas@zfw.com.br
#
# Alternativa STARTTLS (porta 587): EMAIL_USE_SSL=false e EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=vendas@zfw.com.br
ZFW_WHATSAPP_E164=5547984027016
ZFW_WHATSAPP_DISPLAY=+55 47 98402-7016
# Opcional: caminho absoluto/relativo para logo inline na assinatura dos e-mails
# ZFW_EMAIL_LOGO_PATH=apps/orcamentos/assets/branding/zfw-logo-engenharia.png

# URL base do link público no e-mail (dev: localhost · prod: portal.zfw.com.br)
OFERTA_PUBLICA_FRONTEND_URL=http://localhost:5173

# Agente da ponte fiscal local (certificado A3) — mesmo valor em FISCAL_PONTE_AGENT_TOKEN na máquina local
# FISCAL_AGENT_TOKEN=
# CNPJ ZFW (14 dígitos) — portal fiscal / NSU; igual a FISCAL_PONTE_CNPJ na máquina local
# FISCAL_EMPRESA_CNPJ=00000000000000

# Análise SonarQube / SonarCloud: apenas no GitHub Actions (workflow SonarCloud + secret SONAR_TOKEN).
