# Copie para .env na raiz (não commite o .env real).
# DJANGO_DEBUG=true/false — explícito; se omitido, DEBUG segue DJANGO_ENV (ver settings.py).
# DJANGO_ENV=development | production | dev | local — usado pelo docker-compose e como fallback de DEBUG.

DJANGO_SECRET_KEY=trocar-esta-chave
DJANGO_DEBUG=True
DJANGO_ENV=development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

DB_NAME=configurador_painel
DB_USER=configurador_painel
# Obrigatório para `docker compose up`: defina DB_PASSWORD=... no seu .env (o compose não usa valor por omissão).
# Exemplo (não use este valor em produção): crie uma palavra-passe forte só para o Postgres local.
DB_HOST=db
DB_PORT=5432
DB_EXTERNAL_PORT=15432

# Observabilidade (docker-compose.monitoring.yml)
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
# Obrigatório ao subir o overlay de monitoring: defina GRAFANA_ADMIN_PASSWORD=... no seu .env
GRAFANA_ROOT_URL=http://localhost:3000
GRAFANA_DB_NAME=grafana
GRAFANA_DB_USER=grafana
# Obrigatório ao subir o overlay de monitoring: defina GRAFANA_DB_PASSWORD=... no seu .env
TELEGRAM_BOT_NAME=portal_zfw_monitoramento_bot
# Obrigatório para alertas Telegram: defina TELEGRAM_BOT_TOKEN=... no seu .env
# Obrigatório para alertas Telegram: defina TELEGRAM_CHAT_ID=... no seu .env

# Análise SonarQube / SonarCloud: apenas no GitHub Actions (workflow SonarCloud + secret SONAR_TOKEN).
