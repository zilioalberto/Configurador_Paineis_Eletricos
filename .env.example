# Copie para .env na raiz (não commite o .env real).
# DJANGO_DEBUG=true/false — explícito; se omitido, DEBUG segue DJANGO_ENV (ver settings.py).
# DJANGO_ENV=development | production | dev | local — usado pelo docker-compose e como fallback de DEBUG.

DJANGO_SECRET_KEY=trocar-esta-chave
DJANGO_DEBUG=True
DJANGO_ENV=development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=configurador_painel
DB_USER=configurador_painel
# Não deixe vazio: Postgres e Django falham com password em branco.
DB_PASSWORD=configurador_painel
DB_HOST=db
DB_PORT=5432
DB_EXTERNAL_PORT=15432

# SonarQube (opcional) — não sobe com `docker compose up` normal.
# Para subir db + sonarqube do Sonar: docker compose --profile sonar up -d
# SONAR_DB_NAME=sonar
# SONAR_DB_USER=sonar
# SONAR_DB_PASSWORD=sonar
# SONAR_EXTERNAL_PORT=9000
# SONAR_DB_EXTERNAL_PORT=15433
# SONAR_TOKEN=
