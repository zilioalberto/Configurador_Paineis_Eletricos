# Copie para .env.local na pasta frontend para overrides pessoais (arquivos *.local são ignorados pelo git).
#
# Modos:
#   npm run dev          → .env.development (API local)
#   npm run dev:remote   → .env.remote (API remota)
#   npm run build        → .env.production

VITE_API_BASE_URL=http://localhost:8000/api/v1
# VITE_API_AUTH_TOKEN=
# VITE_APP_USER_NAME=
